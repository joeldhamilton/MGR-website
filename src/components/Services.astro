---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    title: "Soybean Roasting",
    subtitle: "For Dairy & Ruminants",
    description: "Boost bypass protein from 26% to over 60%. Our average is 64%. Full fat roasted soybeans are a cost-effective, high-energy protein source for high-producing dairy cows.",
    details: ["64% average bypass protein", "High-energy feed source", "Cost-effective vs. soybean meal"]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.3 24.3 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>`,
    title: "Poultry & Swine",
    subtitle: "Trypsin Inhibitor Reduction",
    description: "Raw soybeans contain trypsin inhibitor that hurts performance. We roast specifically for poultry and swine — less heat than dairy-style, preserving optimal solubility.",
    details: ["Species-specific roasting", "Proper trypsin reduction", "Maintained solubility"]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    title: "Corn & Cereal Grains",
    subtitle: "Gelatinization",
    description: "Roasting breaks long starch chains into shorter, more digestible ones. Cooked corn smells better, tastes better, and fecal starch analysis confirms less waste.",
    details: ["Increased starch digestion", "Improved butterfat & milk protein", "Great for calf feeds"]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.047 8.287 8.287 0 009 9.601a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path d="M12 18a3.75 3.75 0 00.495-7.468 5.99 5.99 0 00-1.925 3.547 5.975 5.975 0 01-2.133-1.001A3.75 3.75 0 0012 18z"/></svg>`,
    title: "Wet Soybeans",
    subtitle: "Dry & Add Value",
    description: "We roast beans up to 25% moisture — drying to storable levels while boosting bypass protein. All your dry matter stays in your bin, not the elevator's.",
    details: ["Handles up to 25% moisture", "Zero dry matter loss", "Far cheaper than elevator docking"]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.249-8.25-3.286zm0 13.036h.008v.008H12v-.008z"/></svg>`,
    title: "Salvage Grain",
    subtitle: "Mold & Mycotoxin Treatment",
    description: "Our 4.6 million BTU burner runs at 3,500°F. CFUs drop to near zero, aflatoxins reduced by 90%. Wet, moldy grain comes out dry, storable, and safe to feed.",
    details: ["90% aflatoxin reduction", "Near-zero CFU counts", "Dried and storable"]
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="32" height="32"><path d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>`,
    title: "High-Oleic Soybeans",
    subtitle: "Premium Feed Production",
    description: "Roasting high-oleic soybeans on-farm creates a closed-loop system: grow, process, and feed — reducing reliance on external suppliers and price fluctuations.",
    details: ["Improved feed efficiency", "Value-added crop use", "Closed-loop system"]
  },
];
---

<section class="services" id="services">
  <div class="container">
    <div class="section-header">
      <p class="section-tag">What We Roast</p>
      <h2>On-Site Roasting Services</h2>
      <p class="section-sub">We bring the roaster to your farm. You supply the grain and someone to move trucks — we handle the rest. LP gas, electricity, feed auger, and boom discharge are all on our service truck.</p>
    </div>
    <div class="services-grid">
      {services.map(service => (
        <div class="service-card">
          <div class="service-icon" set:html={service.icon} />
          <div class="service-content">
            <h3>{service.title}</h3>
            <p class="service-subtitle">{service.subtitle}</p>
            <p class="service-desc">{service.description}</p>
            <ul class="service-details">
              {service.details.map(detail => (
                <li>{detail}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 7rem 2rem;
    background: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-tag {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-rust);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-earth);
    margin-bottom: 1rem;
  }

  .section-sub {
    font-size: 1.1rem;
    color: var(--color-gray);
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: var(--color-cream);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    border-color: var(--color-wheat-dark);
  }

  .service-icon {
    width: 52px;
    height: 52px;
    background: var(--color-earth);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-wheat);
    margin-bottom: 1.25rem;
    padding: 10px;
  }

  .service-icon :global(svg) {
    width: 28px;
    height: 28px;
  }

  h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--color-earth);
    margin-bottom: 0.25rem;
  }

  .service-subtitle {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-rust);
    margin-bottom: 0.75rem;
  }

  .service-desc {
    font-size: 0.95rem;
    color: var(--color-gray);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .service-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .service-details li {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-green);
    padding-left: 1.25rem;
    position: relative;
  }

  .service-details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 8px;
    height: 8px;
    background: var(--color-green-light);
    border-radius: 50%;
  }

  @media (max-width: 720px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
