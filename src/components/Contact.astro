<section class="contact" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="section-tag">Get In Touch</p>
        <h2>Ready to Roast?</h2>
        <p class="contact-intro">Whether you have a few hundred bushels or tens of thousands, we'll bring the roaster to you. Call us to schedule your on-site roasting.</p>

        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            </div>
            <div>
              <p class="contact-label">Phone</p>
              <a href="tel:6085747449" class="contact-value">608-574-7449</a>
              <a href="tel:8003663402" class="contact-value">800-366-3402 (toll free)</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </div>
            <div>
              <p class="contact-label">Email</p>
              <a href="mailto:ericlhamilton@gmail.com" class="contact-value">ericlhamilton@gmail.com</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </div>
            <div>
              <p class="contact-label">Address</p>
              <p class="contact-value">4823 Section Line Rd<br/>Dodgeville, WI 53533</p>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-cta-card">
        <div class="cta-inner">
          <h3>Schedule Your Roasting</h3>
          <p>We roast year-round — not just during harvest. Call us to get on the schedule.</p>
          <a href="tel:8003663402" class="btn-cta">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            Call 800-366-3402
          </a>
          <a href="mailto:ericlhamilton@gmail.com" class="btn-email">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            Email Eric
          </a>
          <div class="cta-note">
            <p>Midwest Grain Roasters, Inc. is a corporation. W-9 available on request.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 7rem 2rem;
    background: var(--color-wheat-light);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .section-tag {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-rust);
    margin-bottom: 0.75rem;
  }

  .contact-info h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-earth);
    margin-bottom: 1rem;
  }

  .contact-intro {
    font-size: 1.05rem;
    color: var(--color-gray);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    background: var(--color-earth);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-wheat);
    flex-shrink: 0;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray);
    margin-bottom: 0.2rem;
  }

  .contact-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-earth);
    display: block;
    line-height: 1.5;
  }

  a.contact-value:hover {
    color: var(--color-rust);
  }

  .contact-cta-card {
    background: var(--color-earth);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }

  .cta-inner {
    padding: 2.5rem;
  }

  .cta-inner h3 {
    font-size: 1.75rem;
    color: white;
    margin-bottom: 0.75rem;
  }

  .cta-inner > p {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .btn-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 1rem;
    background: var(--color-wheat-dark);
    color: var(--color-earth);
    font-weight: 700;
    font-size: 1.05rem;
    border-radius: 10px;
    transition: all 0.2s ease;
    margin-bottom: 0.75rem;
  }

  .btn-cta:hover {
    background: var(--color-wheat);
    transform: translateY(-1px);
  }

  .btn-email {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 1rem;
    background: rgba(255,255,255,0.1);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.2s ease;
  }

  .btn-email:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-1px);
  }

  .cta-note {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .cta-note p {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    text-align: center;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
